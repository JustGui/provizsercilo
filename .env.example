# ProvizSercilo - environment variables example
# Copy to .env and fill in your values. Never commit .env.

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
PORT=8090
LOG_LEVEL=INFO          # TRACE | DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json         # json | pretty

# -----------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------
DATABASE_PATH=./proviz.db
PROFILES_PATH=./profiles.toml

# -----------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------
# Required in production - admin endpoints are disabled without this.
ADMIN_TOKEN=change-me-in-production

# Directory checked first when resolving key_ref values.
# In Docker, mount your secrets to /run/secrets and set this accordingly.
SECRETS_DIR=/run/secrets

# -----------------------------------------------------------------------
# Search behaviour
# -----------------------------------------------------------------------
CACHE_TTL_SECS=3600    # 0 to disable cache
MAX_FALLBACKS=3

# -----------------------------------------------------------------------
# Provider API keys
# These are referenced by key_ref in the api_keys table, not hardcoded here.
# Name them however you like; the DB row key_ref must match exactly.
# -----------------------------------------------------------------------
BRAVE_KEY_1=your-brave-api-key-here
TAVILY_KEY_1=tvly-your-key-here
MOJEEK_KEY_1=your-mojeek-api-key-here
SERPER_KEY_1=your-serper-api-key-here

# -----------------------------------------------------------------------
# SearXNG instances
# key_ref resolves to the full base URL of your SearXNG instance.
# -----------------------------------------------------------------------
SEARXNG_INSTANCE_1=http://localhost:8080
# SEARXNG_INSTANCE_2=https://searx.example.com

# -----------------------------------------------------------------------
# DDG Bridge instances
# key_ref resolves to the base URL of the Python ddgs-bridge service.
# -----------------------------------------------------------------------
DDG_BRIDGE_1=http://localhost:8001
